{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-python.sh",
            "timeout": 30,
            "statusMessage": "Formatting Python..."
          }
        ]
      }
    ]
  }
}
